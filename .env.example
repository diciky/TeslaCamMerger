# TeslaCam Cloud Backend Environment Variables
# Copy this file to .env and fill in your values

# Cloudflare R2 Configuration
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key_here
R2_SECRET_KEY=your_secret_key_here
R2_BUCKET=teslacam-videos
R2_PUBLIC_URL=https://your-public-r2-url.com

# API Security
TESLACAM_API_KEY=your-secure-api-key-here
